# ─────────────────────────────────────────────────────────────
# KDP Pocket AI — environment surface
# Phase 0 documents the full surface. Only the PDF engine gate is
# wired up right now; the rest are placeholders for later phases.
# ─────────────────────────────────────────────────────────────

# --- Supabase (Phase 0 foundation: auth + db) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- PDF storage ---
# MVP uses Supabase Storage (private "books" bucket) — no extra config needed
# beyond the Supabase keys above. Optionally override the bucket name:
SUPABASE_STORAGE_BUCKET=books

# Cloudflare R2 (LATER — switch when scaling; one-line change in lib/storage/index.ts)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# --- OpenRouter (AI: custom word lists + KDP metadata) ---
# Optional: without a key the app falls back to curated word banks + template
# metadata, so the core flow still works. With a key, any niche works.
# Primary:  google/gemini-2.5-flash
# Fallback: deepseek/deepseek-v4-flash   (confirm exact slug in OpenRouter catalog)
OPENROUTER_API_KEY=
OPENROUTER_PRIMARY_MODEL=google/gemini-2.5-flash
OPENROUTER_FALLBACK_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_SITE_URL=http://localhost:3000

# --- Trigger.dev (DEFERRED until generators/jobs phase) ---
TRIGGER_SECRET_KEY=
TRIGGER_PROJECT_ID=

# --- Stripe (DEFERRED until billing phase) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
