{
  "name": "kdp-pocket-ai",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered Amazon KDP book creation platform",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "gate:generate": "tsx scripts/generate-sample.ts",
    "gate:verify": "tsx scripts/verify-pdf.ts",
    "ws:generate": "tsx scripts/generate-word-search.ts",
    "examples:generate": "tsx scripts/generate-examples.ts",
    "examples:validate": "tsx scripts/validate-examples.ts",
    "test:sudoku": "tsx scripts/test-sudoku.ts",
    "test:maze": "tsx scripts/test-maze.ts",
    "test:coloring": "tsx scripts/test-coloring.ts",
    "test:opportunity": "tsx scripts/test-opportunity.ts",
    "coloring:samples": "tsx scripts/generate-coloring-samples.ts",
    "story:poc": "node --env-file=.env.local --import tsx scripts/story-poc.ts",
    "worker": "node --env-file=.env.local --import tsx scripts/worker.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1073.0",
    "@aws-sdk/s3-request-presigner": "^3.1073.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "docx": "^9.7.1",
    "jszip": "^3.10.1",
    "marked": "^18.0.5",
    "next": "^16.2.9",
    "pngjs": "^7.0.0",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@types/node": "22.10.7",
    "@types/pngjs": "^6.0.5",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "autoprefixer": "10.4.20",
    "pdf-lib": "1.17.1",
    "postcss": "8.5.1",
    "puppeteer": "^25.1.0",
    "tailwindcss": "3.4.17",
    "tsx": "4.19.2",
    "typescript": "5.7.3"
  }
}
